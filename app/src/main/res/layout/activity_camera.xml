<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    tools:context=".ui.camera.CameraActivity">

    <FrameLayout
        android:id="@+id/previewContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/black">

        <com.hoyn.common.lib.ui.camera.AspectRatioTextureView
            android:id="@+id/previewView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center" />
    </FrameLayout>

    <!-- Top Controls -->
    <LinearLayout
        android:id="@+id/topControls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:orientation="vertical"
        android:paddingTop="10dp"
        android:paddingBottom="16dp"
        android:paddingHorizontal="16dp">

        <!-- Resolution Buttons Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="30dp"
            android:gravity="center">

            <TextView
                android:id="@+id/btnResolution720p"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/selector_setting_button"
                android:text="@string/camera_resolution_720p"
                android:textColor="@color/camera_setting_button_text"
                android:textSize="14sp"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp" />

            <TextView
                android:id="@+id/btnResolution1080p"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:background="@drawable/selector_setting_button"
                android:text="@string/camera_resolution_1080p"
                android:textColor="@color/camera_setting_button_text"
                android:textSize="14sp"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp" />
        </LinearLayout>

        <!-- FPS Buttons Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            android:gravity="center">

            <TextView
                android:id="@+id/btnFps120"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/selector_setting_button"
                android:text="@string/camera_fps_120"
                android:textColor="@color/camera_setting_button_text"
                android:textSize="14sp"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp" />

            <TextView
                android:id="@+id/btnFps240"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:background="@drawable/selector_setting_button"
                android:text="@string/camera_fps_240"
                android:textColor="@color/camera_setting_button_text"
                android:textSize="14sp"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp" />

            <TextView
                android:id="@+id/btnFps480"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:background="@drawable/selector_setting_button"
                android:text="@string/camera_fps_480"
                android:textColor="@color/camera_setting_button_text"
                android:textSize="14sp"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Bottom Controls -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@color/camera_overlay_bg"
        android:paddingVertical="32dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingHorizontal="24dp">

            <TextView
                android:id="@+id/tvTimer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                android:visibility="gone"
                tools:text="00:00"
                tools:visibility="visible" />

            <TextView
                android:id="@+id/tvZoomRatio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_zoom_indicator"
                android:paddingHorizontal="16dp"
                android:paddingVertical="6dp"
                android:textColor="@color/white"
                android:textSize="14sp"
                tools:text="1.0x" />

            <SeekBar
                android:id="@+id/seekZoom"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:max="1000"
                android:splitTrack="false" />

            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp">

                <View
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_record_button_ring" />

                <View
                    android:id="@+id/btnRecord"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:layout_gravity="center"
                    android:background="@drawable/selector_record_button" />
            </FrameLayout>
        </LinearLayout>
    </FrameLayout>

</FrameLayout>
