<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:name=".MainApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Commonlib">

        <activity
            android:name=".ui.main.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Demo Activities -->
        <activity android:name=".ui.compose.ComposeDemoActivity" />
        <activity android:name=".ui.activity.ToastDemoActivity" />
        <activity android:name=".ui.network.NetworkDemoActivity" />
        <activity android:name=".ui.activity.MmkvDemoActivity" />
        <activity android:name=".ui.activity.LogDemoActivity" />
        <activity android:name=".ui.activity.StatusBarDemoActivity" />

    </application>

</manifest>